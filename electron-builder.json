{
  "appId": "com.diskvisualizer.app",
  "productName": "DiskVisualizer",
  "artifactName": "DiskVisualizer-${version}-mac-${arch}.${ext}",
  "asar": true,
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources/bin",
      "to": "bin",
      "filter": [
        "scanner-macos"
      ]
    }
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "arm64"
        ]
      }
    ]
  }
}
