{
  "appId": "com.example.diskvisualizer",
  "productName": "DiskVisualizer",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources/bin",
      "to": "bin",
      "filter": [
        "scanner-macos",
        "scanner-win.exe",
        "scanner-linux",
        "diskviz-scanner",
        "diskviz-scanner.exe"
      ]
    }
  ],
  "mac": {
    "target": ["dmg"]
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["AppImage"]
  }
}
