{
  "name": "disk-visualizer",
  "version": "0.1.0",
  "description": "Cross-platform disk visualization tool with Electron + React + TypeScript",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:native:scanner": "cargo build --manifest-path native/scanner/Cargo.toml --release",
    "preview": "electron-vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "electron",
    "react",
    "disk-visualizer"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "electron-store": "^11.0.2",
    "fs-extra": "^11.3.4",
    "postprocessing": "^6.38.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtualized": "^9.22.6",
    "tailwindcss": "^4.2.1",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
